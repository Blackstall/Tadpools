{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@tadpools/shared/*": ["packages/shared/src/*"],
      "@tadpools/agents/*": ["packages/agents/src/*"]
    }
  }
}
