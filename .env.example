# Copy this file to .env at the repo root and adjust values for your machine.
# All values below match the defaults in infra/docker-compose.yml.

# PostgreSQL — docker-compose maps host 5433 -> container 5432
PGHOST=localhost
PGPORT=5433
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=tadpools

# MinIO object storage (temporary document store)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123

# Ollama — local LLM used by the agent swarm
OLLAMA_URL=http://localhost:11434
LLM_TIMEOUT_MS=60000

# API server
PORT=4000
